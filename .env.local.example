# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# TODO(constantin): from the Supabase project (Settings → API). Used by the web
# app AND the font-worker (run-worker.ps1 maps these into SUPABASE_URL /
# SUPABASE_SERVICE_ROLE_KEY). Keep the service-role key secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
# TODO(constantin): use live keys in production (sk_live_… / pk_live_…).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# TODO(constantin): from the Stripe webhook endpoint you create for
# /api/webhooks/stripe. Set this to the live endpoint's signing secret in prod.
STRIPE_WEBHOOK_SECRET=

# Monthly price IDs (already created).
STRIPE_PRICE_STUDENT=
STRIPE_PRICE_PRO=

# Annual price IDs.
# TODO(constantin): create the annual Stripe prices (Student €19.99/yr,
# Pro €34.99/yr) and paste their price IDs here.
STRIPE_PRICE_ID_STUDENT_ANNUAL=
STRIPE_PRICE_ID_PRO_ANNUAL=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# TODO(constantin): set this to https://typedhand.com in the production env.
# It drives auth redirect URLs, Stripe success/cancel URLs and OG metadata.
# Leave it as http://localhost:3000 only for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TypedHand
# TODO(constantin): set this to typedhand.com in the production env.
NEXT_PUBLIC_APP_DOMAIN=typedhand.com

# ---------------------------------------------------------------------------
# Analytics (PostHog) — optional
# ---------------------------------------------------------------------------
# Funnel analytics (landing → signup → activation → export → upgrade). Without
# a key, all tracking is a silent no-op, so the app runs fine without it.
# TODO(constantin): create a PostHog project and paste its Project API key.
# Use the EU host (https://eu.i.posthog.com) for an EU project; US otherwise.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
